# =============================================================================
# timesheet-Pro environment variables — copy to .env and fill in values
# NEVER commit .env to source control
# =============================================================================

# --- Database -----------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/timesheetpro?schema=public"

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET="replace-with-at-least-32-random-characters"
# The canonical URL of the app (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"

# --- Encryption key (AES-256-GCM) ----------------------------------------
# Must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-hex-chars"

# --- Approval token signing (HMAC-SHA256) ---------------------------------
# Used to sign approval JWTs. Min 32 characters.
# Generate with: openssl rand -base64 48
APPROVAL_SIGNING_SECRET="replace-with-at-least-32-random-characters"

# --- MFA session cookie HMAC key ------------------------------------------
# Used to sign the MFA-verified cookie. Min 32 characters.
# Generate with: openssl rand -base64 48
MFA_HMAC_KEY="replace-with-at-least-32-random-characters"

# --- Arcjet (rate limiting & bot protection) ------------------------------
# Sign up at https://arcjet.com — required in production
ARCJET_KEY="ajkey_your_key_here"

# --- Xero integration (optional) ------------------------------------------
# Leave blank if not using Xero
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# --- App settings ----------------------------------------------------------
NODE_ENV="production"
