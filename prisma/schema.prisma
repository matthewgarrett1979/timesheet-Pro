generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MANAGER
  USER
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  INVOICED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimesheetGranularity {
  WEEKLY
  MONTHLY
}

enum BillingType {
  TM
  DRAWDOWN
  FIXED
}

enum PhaseStatus {
  ACTIVE
  COMPLETE
  ON_HOLD
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

enum PurchaseOrderStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  COMPLETED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum AuditAction {
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_LOGOUT
  USER_LOCKED
  USER_CREATED
  USER_UPDATED
  MFA_SETUP
  MFA_VERIFIED
  MFA_FAILED
  MFA_RECOVERY_USED
  PASSWORD_CHANGED
  TIME_ENTRY_CREATED
  TIME_ENTRY_UPDATED
  TIME_ENTRY_DELETED
  TIMESHEET_CREATED
  TIMESHEET_UPDATED
  TIMESHEET_SUBMITTED
  TIMESHEET_APPROVED
  TIMESHEET_REJECTED
  INVOICE_GENERATED
  INVOICE_SENT
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_DELETED
  CLIENT_ARCHIVED
  PROJECT_CREATED
  PROJECT_UPDATED
  EXPENSE_CREATED
  EXPENSE_UPDATED
  APPROVAL_TOKEN_CREATED
  APPROVAL_TOKEN_USED
  APPROVAL_TOKEN_EXPIRED
  ADMIN_ACTION
  UNAUTHORISED_ACCESS
  SETTINGS_CHANGED
  FORCE_APPROVED
  FORCE_REJECTED
  RESET_TO_DRAFT
  PARTIALLY_APPROVED
  RESEND_EMAIL
  TIMESHEET_DELETED
  PO_CREATED
  PO_UPDATED
  PO_DELETED
}

// ---------------------------------------------------------------------------
// Core application models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String    // argon2id hash
  role          Role      @default(MANAGER)

  // Brute-force protection
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?

  // MFA
  mfaEnabled    Boolean   @default(false)
  mfaSecretEnc  String?   // AES-256-GCM encrypted TOTP secret
  mfaVerifiedAt DateTime? // Timestamp of first successful TOTP verification
  recoveryCodes String[]  // argon2id-hashed single-use recovery codes

  // Internal cost rate (never exposed to clients / invoices)
  costRate      Decimal?  @db.Decimal(10, 2)

  mustChangePassword Boolean @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clients         Client[]
  timesheets      Timesheet[]
  timeEntries     TimeEntry[]
  projects        Project[]
  expenses        Expense[]
  auditLogs       AuditLog[]
  approvalTokens  ApprovalToken[]
  userProjects    UserProject[]
  purchaseOrders  PurchaseOrder[]

  // NextAuth
  accounts       Account[]
  sessions       Session[]
}

model Client {
  id        String   @id @default(cuid())
  name      String   // Internal display name
  reference String?  // e.g. "GD-2024-001"
  managerId String
  manager   User     @relation(fields: [managerId], references: [id])

  // UK B2B invoice billing details
  companyName         String?  // Legal entity name for invoice header
  tradingName         String?  // Trading name if different from legal name
  addressLine1        String?
  addressLine2        String?
  city                String?
  county              String?
  postcode            String?
  country             String   @default("United Kingdom")
  vatNumber           String?  // VAT registration number (e.g. GB123456789)
  contactName         String?  // Primary billing contact
  contactEmail        String?
  contactPhone        String?
  purchaseOrderNumber String?  // Many defence clients require a PO on invoices
  invoicePaymentTerms Int?     // Days — overrides company default if set
  invoiceCurrency     String   @default("GBP")
  defaultRate         Decimal? @db.Decimal(10, 2)  // Default hourly rate for this client
  notes               String?  // Internal only — never shown on invoice

  // Approval workflow
  approvalType        String   @default("EMAIL")     // EMAIL | PORTAL | NONE
  approvalGranularity String   @default("TIMESHEET") // TIMESHEET | MONTHLY | QUARTERLY

  // Soft-delete / archive
  isArchived          Boolean  @default(false)

  timesheets  Timesheet[]
  timeEntries TimeEntry[]
  projects    Project[]
  expenses    Expense[]
  invoices    Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
}

model Project {
  id               String      @id @default(cuid())
  name             String
  description      String?
  clientId         String
  client           Client      @relation(fields: [clientId], references: [id])
  managerId        String
  manager          User        @relation(fields: [managerId], references: [id])
  active           Boolean     @default(true)
  rateOverride     Decimal?    @db.Decimal(10, 2)  // Overrides client defaultRate when set

  // Billing type and budget fields
  billingType      BillingType @default(TM)
  budgetHours      Decimal?    @db.Decimal(10, 2)
  contingencyHours Decimal?    @db.Decimal(10, 2)
  budgetValue      Decimal?    @db.Decimal(10, 2)
  drawdownRate     Decimal?    @db.Decimal(10, 2)

  phases          ProjectPhase[]
  timeEntries     TimeEntry[]
  userProjects    UserProject[]
  purchaseOrders  PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([clientId])
}

model UserProject {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  assignedBy String   // userId of the admin/manager who made the assignment

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model ProjectPhase {
  id               String      @id @default(cuid())
  projectId        String
  project          Project     @relation(fields: [projectId], references: [id])
  name             String
  description      String?
  billingType      BillingType @default(TM)
  budgetHours      Decimal?    @db.Decimal(10, 2)
  contingencyHours Decimal?    @db.Decimal(10, 2)
  budgetValue      Decimal?    @db.Decimal(10, 2)
  startDate        DateTime?   @db.Date
  endDate          DateTime?   @db.Date
  status           PhaseStatus @default(ACTIVE)

  timeEntries    TimeEntry[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseId          String?
  phase            ProjectPhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  poNumber         String
  sowReference     String?
  description      String?
  value            Decimal?            @db.Decimal(10, 2)
  currency         String              @default("GBP")
  issueDate        DateTime?           @db.Date
  expiryDate       DateTime?           @db.Date
  status           PurchaseOrderStatus @default(ACTIVE)
  sowSigned        Boolean             @default(false)
  poSigned         Boolean             @default(false)
  documentUrl      String?
  documentFileName String?
  notes            String?
  createdById      String
  createdBy        User                @relation(fields: [createdById], references: [id])

  timeEntries TimeEntry[]
  invoices    Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phaseId])
  @@index([createdById])
  @@index([status])
}

model TimeCategory {
  id         String      @id @default(cuid())
  name       String
  colour     String      @default("#6366f1")  // hex colour for UI display
  isBillable Boolean     @default(true)
  sortOrder  Int         @default(0)

  timeEntries TimeEntry[]

  createdAt DateTime @default(now())
}

model Timesheet {
  id           String               @id @default(cuid())
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id])
  managerId    String
  manager      User                 @relation(fields: [managerId], references: [id])
  periodStart  DateTime             @db.Date
  periodEnd    DateTime             @db.Date
  granularity  TimesheetGranularity @default(WEEKLY)
  entries      TimeEntry[]
  status       TimesheetStatus      @default(DRAFT)
  rejectionNote String?

  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedBy     String?   // email of the client-side approver
  reminderCount  Int       @default(0)

  invoiceId   String?

  approvalTokens ApprovalToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([clientId])
  @@index([status])
}

// TimeEntry: a single unit of work — exists independently until bundled into a Timesheet
model TimeEntry {
  id          String          @id @default(cuid())
  date        DateTime        @db.Date
  clientId    String?
  client      Client?         @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id])
  phaseId     String?
  phase       ProjectPhase?   @relation(fields: [phaseId], references: [id])
  categoryId  String?
  category    TimeCategory?   @relation(fields: [categoryId], references: [id])
  managerId   String?
  manager     User?           @relation(fields: [managerId], references: [id])
  timesheetId     String?
  timesheet       Timesheet?      @relation(fields: [timesheetId], references: [id], onDelete: SetNull)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  hours           Decimal         @db.Decimal(5, 2)
  description     String
  isBillable      Boolean         @default(true)
  status          TimeEntryStatus @default(DRAFT)
  invoiced        Boolean         @default(false)
  receiptPath     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([clientId])
  @@index([projectId])
  @@index([timesheetId])
  @@index([purchaseOrderId])
  @@index([date])
}

model Expense {
  id          String        @id @default(cuid())
  description String
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("GBP")
  date        DateTime      @db.Date
  category    String
  receiptPath String?
  managerId   String
  manager     User          @relation(fields: [managerId], references: [id])
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  status      ExpenseStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([clientId])
}

// Single-use HMAC-signed JWT approval tokens sent to clients
model ApprovalToken {
  id          String    @id @default(cuid())
  jti         String    @unique // JWT ID — used for single-use enforcement
  clientId    String
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  usedAt      DateTime? // null = not yet used
  expiresAt   DateTime

  createdAt DateTime @default(now())

  @@index([timesheetId])
  @@index([jti])
}

model Invoice {
  id                  String        @id @default(cuid())
  clientId            String
  client              Client        @relation(fields: [clientId], references: [id])
  managerId           String
  timesheetIds        String[]
  xeroInvoiceId       String?
  xeroAccessTokenEnc  String?       // AES-256-GCM encrypted
  xeroRefreshTokenEnc String?       // AES-256-GCM encrypted
  amount              Decimal        @db.Decimal(10, 2)
  currency            String         @default("GBP")
  status              InvoiceStatus  @default(DRAFT)
  purchaseOrderId     String?
  purchaseOrder       PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([clientId])
  @@index([purchaseOrderId])
}

// Global appearance / theme settings — singleton row with id = 'global'
model AppSettings {
  id              String   @id @default("global")
  primaryColor    String   @default("#1e293b")   // sidebar / nav background
  accentColor     String   @default("#2563eb")   // active items, buttons
  backgroundColor String   @default("#f9fafb")   // page background
  fontFamily      String   @default("inter")     // inter | system | georgia | mono
  navStyle        String   @default("sidebar")   // sidebar | topbar
  compactMode     Boolean  @default(false)

  // Notification / reminder settings
  notificationsEnabled Boolean @default(false)
  reminderThreshold    Int     @default(35)     // minimum hours threshold
  reminderDayOfWeek    Int     @default(5)      // 1=Mon … 7=Sun (ISO weekday)
  reminderTime         String  @default("17:00") // HH:MM UTC

  updatedAt       DateTime @updatedAt
}

// Immutable audit log — rows are never updated or deleted by the application
model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  resource   String      // e.g. "timesheet", "auth", "client"
  resourceId String?
  metadata   Json?       // sanitised — no passwords, no tokens
  ipAddress  String?
  userAgent  String?
  success    Boolean

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// NextAuth required models
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Database-backed sessions allow server-side revocation
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  mfaVerified  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
